{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/dashboard",
      "destination": "/habitflow-dashboard",
      "permanent": false
    },
    {
      "source": "/login",
      "destination": "/habitflow-auth",
      "permanent": false
    },
    {
      "source": "/upgrade",
      "destination": "/habitflow-upgrade",
      "permanent": false
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" }
      ]
    }
  ]
}
